# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ENABLE_OPENAI_WEB_SEARCH=true

# Vercel web app -> DigitalOcean worker
AGENT_BACKEND_URL=http://127.0.0.1:8080
AGENT_BACKEND_TOKEN=

# DigitalOcean managed PostgreSQL
DATABASE_URL=

# DigitalOcean Spaces, S3-compatible
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=ai-research-agent-kb-a01bd200
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=

# Notion
NOTION_API_KEY=
NOTION_PROMPTS_DATABASE_ID=
NOTION_RESPONSES_DATABASE_ID=

# Local development only
LOCAL_SQLITE_PATH=./data/local.db
